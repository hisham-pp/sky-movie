{
  "name": "@sky-movie/desktop-app",
  "version": "0.3.1",
  "description": "Local-first desktop movie and TV library manager.",
  "homepage": "https://github.com/hisham-pp/sky-movie",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "package": "electron-builder",
    "package:all": "electron-builder --win --mac --linux",
    "package:current": "electron-builder",
    "package:linux": "electron-builder --linux",
    "package:mac": "electron-builder --mac",
    "package:win": "powershell -NoProfile -ExecutionPolicy Bypass -File ..\\scripts\\build-windows-app.ps1",
    "package:win:builder": "electron-builder --win nsis dir",
    "package:win:dir": "electron-builder --win dir",
    "package:win:installer": "electron-builder --win nsis",
    "postinstall": "electron-builder install-app-deps",
    "preview": "electron-vite preview",
    "rebuild:electron": "electron-builder install-app-deps",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit"
  },
  "author": "Sky Movie",
  "desktopName": "sky-movie",
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "artplayer": "^5.4.0",
    "better-sqlite3": "^12.2.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "electron": "^37.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.0.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
