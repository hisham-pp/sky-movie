# Copy this file to envs/.env.r2 and fill in local secrets.
# envs/.env.r2 is ignored by git.

# Cloudflare account id from the Workers & Pages / R2 dashboard URL.
CLOUDFLARE_ACCOUNT_ID=

# R2 bucket that stores release artifacts.
CLOUDFLARE_R2_BUCKET=sky-movie-releases

# R2 API token credentials with Object Read & Write permission for the bucket.
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# Public bucket URL or custom domain used by the website download links.
# Example: https://downloads.example.com
CLOUDFLARE_R2_PUBLIC_BASE_URL=

# Optional prefix inside the bucket. The script adds v<version>/ below this.
# Example output key: releases/v0.1.0/Sky Movie-0.1.0-x64-Setup.exe
CLOUDFLARE_R2_PREFIX=releases
