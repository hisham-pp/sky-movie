# Copy this file to .env.drive and fill in local secrets.
# .env.drive is ignored by git.

# Parent Google Drive folder where version folders such as v0.1.0 will be created.
GOOGLE_DRIVE_FOLDER_ID=

# Preferred: path to a Google service account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\sky-movie-drive-service-account.json

# Alternative: raw service account JSON on one line.
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
