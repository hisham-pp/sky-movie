# GitHub Releases Configuration
# Copy this file to envs/.env.github and fill in your values.
# Never commit the actual envs/.env.github file.

# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Required scopes: repo (or public_repo for public repositories)
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# Optional: Override repository owner and name
# By default, these are detected from git remote origin
# GITHUB_OWNER=your-github-username
# GITHUB_REPO=sky-movie
