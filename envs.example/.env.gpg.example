# GPG Configuration for Linux Package Signing
# Copy this file to envs/.env.gpg and fill in your values

# GPG Private Key (ASCII-armored format)
# Generate with: gpg --armor --export-secret-keys your@email.com
GPG_PRIVATE_KEY=-----BEGIN PGP PRIVATE KEY BLOCK-----
...your private key here...
-----END PGP PRIVATE KEY BLOCK-----

# GPG Passphrase (the password you set when creating the key)
GPG_PASSPHRASE=your-passphrase-here

# Optional: GPG Key ID (if you want to specify it explicitly)
# You can find this with: gpg --list-secret-keys --keyid-format LONG
# GPG_KEY_ID=YOUR_KEY_ID_HERE
